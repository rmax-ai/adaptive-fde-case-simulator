# AFCS Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Database
DATABASE_URL=postgresql+psycopg://afcs:afcs_secret@localhost:5432/afcs

# For local development with SQLite (default if DATABASE_URL is not set):
# DATABASE_URL=sqlite:///afcs.db

# Server
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=info
